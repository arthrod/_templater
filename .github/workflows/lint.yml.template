  #   steps:
  #     - uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0  # v7.0.0
  #       with:
  #         persist-credentials: false
  #     - id: detect
  #       run: '[ -f Cargo.toml ] && echo "present=true" >> "$GITHUB_OUTPUT" || true'
  #     - if: steps.detect.outputs.present == 'true'
