  #     - id: detect
  #       run: '[ -f go.mod ] && echo "present=true" >> "$GITHUB_OUTPUT" || true'
  #     - if: steps.detect.outputs.present == 'true'
  #       uses: actions/setup-go@4a3601121dd01d1626a1e23e37211e3254c1c06c  # v6.4.0
